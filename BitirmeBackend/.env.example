# PostgreSQL connection (psycopg v3 driver)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/myapp

# Server
HOST=0.0.0.0
PORT=3001

# Comma-separated list of allowed CORS origins (frontend dev server)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Auto-create the helper tables (users, user_profiles, saved_recipes, meal_plans)
# on startup. The existing "recipes" table is never modified.
AUTO_CREATE_TABLES=true
